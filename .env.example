# ─────────────────────────────────────────────────────────────────────────────
# Trionic Adalat — local dev environment template
#
# Copy this file to `.env.local` (gitignored) and you're ready to run.
# Most of you only need the public values below to develop locally.
#
# For the secret values (service-role key, DeepSeek API key, etc.):
# - They live in GitHub Secrets + Vercel env vars (server-only).
# - You do NOT need them to develop most features locally.
# - If you genuinely need them for your task, comment on your issue and tag
#   a repo manager (@Dhruv5353 or @Sohil2085) — we'll provision a per-intern
#   access path. Do NOT paste them in chat.
# ─────────────────────────────────────────────────────────────────────────────


# ─── Supabase ────────────────────────────────────────────────────────────────
# These two are PUBLIC by design — Supabase ships them inside the client JS
# bundle in production. Safe to commit, safe to share, safe to use locally.
#
# To get DASHBOARD access (so you can see schema, run SQL, watch logs), wait
# for the Trionic team-member invite to your email. See docs/INTERN_ACCESS.md.

NEXT_PUBLIC_SUPABASE_URL="https://zawdoeusvkldgrigfbow.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Inphd2RvZXVzdmtsZGdyaWdmYm93Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3Nzk5NTA1NTksImV4cCI6MjA5NTUyNjU1OX0.6gWNB2dvQsc5QVjYHkcDkcumkF314enpxlqk-4mX3cI"


# ─── Supabase server-only (DO NOT COMMIT, DO NOT SHARE) ──────────────────────
# These bypass RLS and have full DB access. Lives in GitHub Secrets + Vercel.
# Interns: leave these blank for local dev — RLS via the anon key is enough
# for everything you'll build locally.

SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_DB_PASSWORD=""


# ─── LLM providers (DO NOT COMMIT, DO NOT SHARE) ─────────────────────────────
# Server-only. Lives in GitHub Secrets + Vercel.
# DeepSeek is our primary; others are configured in the LLM Router for fallback.

DEEPSEEK_API_KEY=""
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
GOOGLE_API_KEY=""
GEMINI_API_KEY=""


# ─── Observability ───────────────────────────────────────────────────────────
# Sentry DSN is technically public but we keep it out of the bundle for hygiene.
SENTRY_DSN=""


# ─── Local app config (safe to set whatever you want) ────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_DEFAULT_LANGUAGE="en"
