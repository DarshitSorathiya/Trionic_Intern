{
  "name": "trionic-ai-adalat",
  "version": "0.0.1",
  "private": true,
  "description": "Multilingual agentic AI assistant for Indian legal drafting and research",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter web dev",
    "lint": "pnpm -r --parallel lint",
    "typecheck": "pnpm -r --parallel typecheck",
    "test": "pnpm -r --parallel test",
    "ingest:crpc": "pnpm --filter @trionic/pageindex ingest:crpc",
    "validate:crpc": "pnpm --filter @trionic/pageindex validate:crpc",
    "ingest:cpc": "pnpm --filter @trionic/pageindex ingest:cpc",
    "validate:cpc": "pnpm --filter @trionic/pageindex validate:cpc"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.1",
    "dotenv": "^17.4.2",
    "openai": "^6.42.0"
  }
}
