          "name": "GET /api/admin/audit-export (admin only — expect 403 for normal user)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Normal users get 403; admin users get CSV download",
                  "pm.test('Returns 403 or 200', () => {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 403]);",
                  "});",
                  "if (pm.response.code === 200) {",
                  "  pm.test('Content-Type is text/csv', () => {",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.include('text/csv');",
                  "  });",
                  "  pm.test('Content-Disposition has attachment', () => {",
                  "    pm.expect(pm.response.headers.get('Content-Disposition')).to.include('attachment');",
                  "  });",
                  "  console.log('CSV preview (first 200 chars):', pm.response.text().slice(0, 200));",
                  "} else {",
                  "  console.log('403 expected for non-admin user — correct behaviour');",
