    {
      "name": "4. Audit Log — GET /api/audit/:id",
      "item": [
        {
          "name": "GET /api/audit/:document_id (returns traces, PII redacted)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Has traces array', () => pm.expect(json.traces).to.be.an('array'));",
                  "console.log('Traces found:', json.traces.length);",
                  "// Verify PII redaction is working",
                  "json.traces.forEach((t, i) => {",
                  "  if (t.error_message) {",
                  "    pm.test(`Trace ${i} error_message has no raw email`, () => {",
                  "      pm.expect(t.error_message).to.not.match(/[a-z0-9._%+\\-]+@[a-z0-9.\\-]+\\.[a-z]{2,}/i);",
                  "    });",
                  "    pm.test(`Trace ${i} error_message has no 10-digit phone`, () => {",
                  "      pm.expect(t.error_message).to.not.match(/[6-9]\\d{9}/);",
                  "    });",
                  "  }",
                  "});",
                  "// Verify shape matches @trionic/shared AgentTrace",
                  "json.traces.forEach((t, i) => {",
                  "  pm.test(`Trace ${i} has required fields`, () => {",
                  "    pm.expect(t.agent).to.be.a('string');",
                  "    pm.expect(t.model).to.be.a('string');",
                  "    pm.expect(t.tokens_in).to.be.a('number');",
                  "    pm.expect(t.tokens_out).to.be.a('number');",
                  "    pm.expect(t.status).to.be.oneOf(['ok', 'error', 'rejected']);",
                  "  });",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Cookie", "value": "{{AUTH_COOKIE}}" }],
            "url": {
              "raw": "{{BASE_URL}}/api/audit/{{DOCUMENT_ID}}",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "audit", "{{DOCUMENT_ID}}"]
            }
          }
        },
